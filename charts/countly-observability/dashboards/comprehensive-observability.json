  "panels": [
    {
      "id": 1,
      "title": "Service Health Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Cluster Health",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(up)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "name_and_value",
        "text": {
          "titleSize": 14,
          "valueSize": 20
        }
      }
    },
    {
      "id": 3,
      "title": "MongoDB Status",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(mongodb_up)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          },
          "unit": "short",
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "1": {
                  "text": "PARTIAL",
                  "color": "yellow"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "2": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "3": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "name_and_value"
      }
    },
    {
      "id": 4,
      "title": "Kafka Brokers",
      "type": "stat",
      "targets": [
        {
          "expr": "{__name__=~\"kafka_controller_activebrokercount.*\", namespace=\"kafka\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
