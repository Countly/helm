      "id": 14,
      "title": "Network Traffic",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|flannel.*|cali.*|cbr.*\"}[$interval]))",
          "refId": "A",
          "legendFormat": "Network RX"
