      "id": 10,
      "title": "Kafka Message Throughput",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"kafka_brokertopic_messagesin.*\", namespace=\"kafka\"}[$interval]))",
          "refId": "A",
          "legendFormat": "Messages In/sec"
