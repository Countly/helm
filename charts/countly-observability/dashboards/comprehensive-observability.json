    },
    {
      "id": 5,
      "title": "Kafka Connect",
      "type": "stat",
      "targets": [
        {
          "expr": "sum({__name__=~\"kafka_connect_connector_running_task_count.*\", namespace=\"kafka\"})",
          "refId": "A"
