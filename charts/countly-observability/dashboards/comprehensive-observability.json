    {
      "id": 12,
      "title": "Node CPU Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "avg(rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[$interval])) * 100",
          "refId": "A",
          "legendFormat": "Overall CPU Usage %"
