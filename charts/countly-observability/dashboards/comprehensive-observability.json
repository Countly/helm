      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "xAxis": {
        "show": true
      },
      "yAxes": [
        {
          "label": "throughput",
          "show": true,
          "unit": "short"
        },
        {
          "show": true
