    {
      "id": 8,
      "title": "Application Performance Metrics",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 9,
      "title": "MongoDB Operations/sec",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(mongodb_ss_opcounters_query[$interval]))",
          "refId": "A",
          "legendFormat": "Queries/sec"
        },
        {
          "expr": "sum(rate(mongodb_ss_opcounters_insert[$interval]))",
          "refId": "B",
          "legendFormat": "Inserts/sec"
        },
        {
          "expr": "sum(rate(mongodb_ss_opcounters_update[$interval]))",
          "refId": "C",
          "legendFormat": "Updates/sec"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "xAxis": {
        "show": true
      },
      "yAxes": [
        {
          "label": "ops/sec",
          "show": true,
          "unit": "short"
        },
        {
          "show": true
        }
      ],
      "legend": {
        "show": true,
        "alignAsTable": true,
        "rightSide": false,
        "avg": true,
        "current": true,
        "max": true,
        "min": false,
        "total": false,
        "values": true
      }
    },
