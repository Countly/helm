{
  "id": null,
  "title": "Kafka Cluster Comprehensive Monitoring",
  "tags": [
    "kafka",
    "cluster",
    "brokers",
    "strimzi",
    "observability"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "hideControls": false,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values({__name__=~\"kafka_controller_activebrokercount.*\"}, namespace)",
        "current": {
          "value": "kafka",
          "text": "kafka"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "instance",
        "type": "query",
        "query": "label_values({__name__=~\"kafka_brokertopic_bytesin.*\"}{namespace=\"$namespace\"}, instance)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "topic",
        "type": "query",
        "query": "label_values({__name__=~\"kafka_brokertopic_bytesin.*\"}{namespace=\"$namespace\"}, topic)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Kafka Cluster Health Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Active Brokers",
      "type": "stat",
      "targets": [
        {
          "expr": "{__name__=~\"kafka_controller_activebrokercount.*\"}{namespace=\"$namespace\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 3
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Fenced Brokers",
      "type": "stat",
      "targets": [
        {
          "expr": "{__name__=~\"kafka_controller_fencedbrokercount.*\"}{namespace=\"$namespace\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Timed Out Broker Heartbeats",
      "type": "stat",
      "targets": [
        {
          "expr": "{__name__=~\"kafka_controller_timedoutbrokerheartbeatcount.*\"}{namespace=\"$namespace\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Cluster Status",
      "type": "stat",
      "targets": [
        {
          "expr": "up{namespace=\"$namespace\", job=~\".*kafka.*\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short",
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Topic & Message Throughput",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 7,
      "title": "Messages In Per Second",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"kafka_brokertopic_messagesin.*\"}{namespace=\"$namespace\", topic=~\"$topic\"}[5m])) by (topic)",
          "refId": "A",
          "legendFormat": "Messages/sec - {{topic}}"
        },
        {
          "expr": "sum(rate({__name__=~\"kafka_brokertopic_messagesin.*\"}{namespace=\"$namespace\"}[5m]))",
          "refId": "B",
          "legendFormat": "Total Messages/sec"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "xAxis": {
        "show": true
      },
      "yAxes": [
        {
          "label": "messages/sec",
          "show": true,
          "unit": "short"
        },
        {
          "show": true
        }
      ],
      "legend": {
        "show": true,
        "alignAsTable": true,
        "rightSide": false,
        "avg": true,
        "current": true,
        "max": true,
        "min": false,
        "total": false,
        "values": true
      }
    },
