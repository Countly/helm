{
  "id": null,
  "title": "Kafka Consumer Lag Deep-Dive",
  "tags": [
    "kafka",
    "consumer",
    "lag",
    "strimzi",
    "deep-dive"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "hideControls": false,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values({__name__=~\"kafka_.*\"}, kafka_cluster)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "cluster",
        "type": "query",
        "query": "label_values(kafka_brokertopic_messagesin, cluster)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "topic",
        "type": "query",
        "query": "label_values(kafka_brokertopic_messagesin{cluster=~\"$cluster\"}, topic)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "group",
        "type": "query",
        "query": "label_values(kafka_connect_connector_running_task_count__4, connector)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Consumer Lag Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Total Message Production Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(kafka_brokertopic_messagesin{topic=~\"$topic\"}[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "unit": "msg/sec"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "name_and_value"
      }
    },
    {
      "id": 3,
      "title": "Active Kafka Connect Tasks",
      "type": "stat",
      "targets": [
        {
          "expr": "(kafka_connect_connector_running_task_count__0 or kafka_connect_connector_running_task_count__4 or kafka_connect_connector_running_task_count__1 or kafka_connect_connector_running_task_count__2 or kafka_connect_connector_running_task_count__3)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 4
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
