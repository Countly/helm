{
  "id": null,
  "title": "ClickHouse Comprehensive Monitoring",
  "tags": [
    "clickhouse",
    "database",
    "analytics",
    "observability"
  ],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "hideControls": false,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values(up{job=~\"clickhouse.*\"}, namespace)",
        "current": {
          "value": "clickhouse",
          "text": "clickhouse"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(up{job=~\"clickhouse.*\"}, instance)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "cluster",
        "type": "query",
        "query": "label_values(ClickHouseAsyncMetrics_Uptime, cluster)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "ClickHouse Cluster Health Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "targets": [
        {
          "expr": "max(ClickHouseAsyncMetrics_OSUptime{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "green",
                "value": 3600
              }
            ]
          },
          "unit": "s"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "name_and_value"
      }
    },
    {
      "id": 3,
      "title": "HTTP Connections",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(ClickHouseMetrics_HTTPConnection{instance=~\"$instance\"})",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "orientation": "auto",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "name_and_value"
      }
    },
    {
      "id": 4,
      "title": "Memory Tracking",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(ClickHouseMetrics_MemoryTracking{instance=~\"$instance\"})",
