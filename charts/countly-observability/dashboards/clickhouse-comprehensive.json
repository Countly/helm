        {
          "expr": "ClickHouseAsyncMetrics_LoadAverage1{instance=~\"$instance\"}",
          "refId": "A",
          "legendFormat": "1min - {{instance}}"
        },
        {
          "expr": "ClickHouseAsyncMetrics_LoadAverage5{instance=~\"$instance\"}",
          "refId": "B",
          "legendFormat": "5min - {{instance}}"
        },
        {
          "expr": "ClickHouseAsyncMetrics_LoadAverage15{instance=~\"$instance\"}",
          "refId": "C",
          "legendFormat": "15min - {{instance}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
