    {
      "id": 7,
      "title": "Task Status by Connector",
      "type": "graph",
      "targets": [
        {
          "expr": "{__name__=~\"kafka_connect_connector_running_task_count.*\", namespace=\"$namespace\", connector=~\"$connector\"}",
          "refId": "A",
          "legendFormat": "Running - {{connector}}"
        },
        {
          "expr": "{__name__=~\"kafka_connect_connector_failed_task_count.*\", namespace=\"$namespace\", connector=~\"$connector\"}",
          "refId": "B",
          "legendFormat": "Failed - {{connector}}"
