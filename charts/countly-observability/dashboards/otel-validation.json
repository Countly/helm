    },
    "description": "Validation dashboard to verify OTEL → Alloy → Prometheus metrics pipeline for Countly services",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "panels": [],
            "title": "OTEL Pipeline Validation",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "description": "Verify Countly services are sending OTEL metrics through Alloy to Prometheus",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "id": 2,
            "options": {
                "legend": {
                    "calcs": ["lastNotNull"],
                    "displayMode": "table",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "expr": "countly_http_server_duration_milliseconds_count",
                    "legendFormat": "{{service_name}} - {{instance}}"
                }
            ],
            "title": "Countly Services - Up Status",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "description": "Check for any OTEL-specific metrics from Countly services",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "id": 3,
            "options": {
                "legend": {
                    "calcs": ["lastNotNull"],
                    "displayMode": "table",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "expr": "rate(countly_http_server_duration_milliseconds_count[5m])",
                    "legendFormat": "{{service_name}} - HTTP Requests/sec"
                },
                {
                    "expr": "histogram_quantile(0.95, rate(countly_http_server_duration_milliseconds_bucket[5m]))",
                    "legendFormat": "{{service_name}} - 95th percentile response time"
                }
            ],
            "title": "Countly HTTP Metrics (OTEL)",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "description": "Node.js specific metrics from OTEL instrumentation",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "unit": "percent"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 9
            },
            "id": 4,
            "options": {
                "legend": {
                    "calcs": ["lastNotNull"],
                    "displayMode": "table",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "expr": "nodejs_eventloop_utilization_ratio{service_name=~\"countly.*\"} * 100",
                    "legendFormat": "{{service_name}} - Event Loop Utilization"
                },
                {
                    "expr": "process_cpu_percent{job=~\"countly.*\"}",
                    "legendFormat": "{{job}} - CPU Usage"
                }
            ],
            "title": "Node.js Runtime Metrics (OTEL)",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "description": "Memory usage metrics from OTEL instrumentation",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "unit": "bytes"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 9
            },
            "id": 5,
            "options": {
                "legend": {
                    "calcs": ["lastNotNull"],
                    "displayMode": "table",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "expr": "nodejs_heap_used_bytes{service_name=~\"countly.*\"}",
                    "legendFormat": "{{service_name}} - Heap Used"
                },
                {
                    "expr": "process_resident_memory_bytes{job=~\"countly.*\"}",
                    "legendFormat": "{{job}} - Resident Memory"
                }
            ],
            "title": "Memory Metrics (OTEL)",
            "type": "timeseries"
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 17
            },
            "id": 6,
            "panels": [],
            "title": "OTEL Pipeline Health",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "description": "Alloy OTEL receiver metrics to verify data ingestion",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 18
            },
            "id": 7,
            "options": {
                "legend": {
                    "calcs": ["lastNotNull"],
                    "displayMode": "table",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "expr": "rate(otelcol_receiver_accepted_metric_points{job=\"alloy-internal\"}[5m])",
                    "legendFormat": "Metrics Received/sec"
                },
                {
                    "expr": "rate(otelcol_receiver_accepted_spans{job=\"alloy-internal\"}[5m])",
                    "legendFormat": "Traces Received/sec"
                }
            ],
            "title": "Alloy OTEL Receiver Stats",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "description": "Prometheus remote write statistics from Alloy",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 18
            },
            "id": 8,
            "options": {
                "legend": {
                    "calcs": ["lastNotNull"],
                    "displayMode": "table",
                    "placement": "right"
                }
            },
            "targets": [
                {
                    "expr": "rate(prometheus_remote_write_samples_total{job=\"alloy-internal\"}[5m])",
                    "legendFormat": "Samples Sent to Prometheus/sec"
                },
                {
                    "expr": "prometheus_remote_write_samples_pending{job=\"alloy-internal\"}",
                    "legendFormat": "Samples Pending"
                }
            ],
            "title": "Prometheus Remote Write Stats",
            "type": "timeseries"
        }
    ],
