          "expr": "sum(rate(countly_http_server_duration_milliseconds_sum{namespace=~\"$namespace\", instance=~\"$instance\"}[5m])) / sum(rate(countly_http_server_duration_milliseconds_count{namespace=~\"$namespace\", instance=~\"$instance\"}[5m]))",
          "refId": "D",
