  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "query": "label_values(countly_http_server_duration_milliseconds_count, namespace)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(countly_http_server_duration_milliseconds_count{namespace=~\"$namespace\"}, instance)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "method",
        "type": "query",
        "query": "label_values(countly_http_server_duration_milliseconds_count{namespace=~\"$namespace\"}, http_method)",
        "current": {
          "value": "All",
          "text": "All"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 1,
        "regex": "",
        "sort": 1
      },
      {
        "name": "status",
        "type": "query",
        "query": "label_values(countly_http_server_duration_milliseconds_count{namespace=~\"$namespace\"}, http_status_code)",
