# Countly TLS Certificate Configuration - Template
# Use this only for manual bring-your-own TLS secret workflows.
# If you use Secret Manager + External Secrets, prefer ingress.tls.externalSecret
# in countly.yaml instead of managing this file.

# Base64 encoded TLS certificate (full chain)
TLS_CRT=
# Base64 encoded TLS private key
TLS_KEY=
